void updateStatusScreen(String line1, String line2, uint16_t color) {
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(color, TFT_BLACK);
  tft.drawCentreString(line1, 120, 100, 2);
  tft.drawCentreString(line2, 120, 130, 2);
}

void setup() {
  Serial.begin(115200);
  pinMode(SETTINGS_BUTTON_PIN, INPUT_PULLUP);
  pinMode(21, OUTPUT); digitalWrite(21, HIGH);
  
  delay(1000); 
  
  tft.init(); 
  tft.setRotation(0); 
  tft.fillScreen(TFT_BLACK);

  spr.setColorDepth(8); 
  spr.createSprite(240, 240);
  
  tft.setTextColor(TFT_GREEN, TFT_BLACK);
  tft.drawCentreString("SYSTEM BOOT...", 120, 110, 2);

  loadConfiguration();

  preferences.begin("radar-config", true);
  isConfigured = preferences.getBool("configured", false);
  bool forcePortal = preferences.getBool("force_portal", false);
  preferences.end();

  if (forcePortal) {
    preferences.begin("radar-config", false); 
    preferences.putBool("force_portal", false); 
    preferences.end();
    isConfigured = false;
  }

  if (isConfigured && storedSsid.length() > 0) {
    WiFi.persistent(false); 
    WiFi.mode(WIFI_STA); 
    WiFi.setHostname("DeskRadar");
    WiFi.begin(storedSsid.c_str(), storedPass.c_str()); 
    int timeout = 0;
    while (WiFi.status() != WL_CONNECTED && timeout < 20) { delay(500); timeout++; }
  }

  if (WiFi.status() != WL_CONNECTED) {
    isConfigured = false;
    runNetworkScan();
    WiFi.mode(WIFI_AP);
    WiFi.softAP("DeskRadar-Setup");
    server.on("/", [](){
      server.send(200, "text/html", "<html><body><h2>DeskRadar Setup</h2><form action='/save' method='POST'>PIN: <input type='password' name='pin'><br><button type='submit'>Save</button></form></body></html>");
    });
    server.on("/save", [](){
      needsReboot = true;
      server.send(200, "text/html", "Rebooting...");
    });
    server.begin();
    updateStatusScreen("PORTAL ACTIVE", "192.168.4.1", TFT_GREEN);
  } else {
    isConfigured = true;
  }
}

void loop() {
  if (digitalRead(SETTINGS_BUTTON_PIN) == LOW) { ESP.restart(); }
  if (!isConfigured) { server.handleClient(); return; }
  
  if (millis() - lastFetchTime >= pollInterval) {
    fetchAndMapFlights(); 
    lastFetchTime = millis(); 
  }

  if (millis() - lastDrawTime > 40) {
    renderRadarFrame();
    lastDrawTime = millis();
  }
}

